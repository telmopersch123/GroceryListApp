{
  "expo": {
    "name": "GroceryList",
    "slug": "GroceryListNew",
    "jsEngine": "jsc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/iconApp.png",
    "scheme": "grocerylist",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "icon": "./assets/images/iconApp.png",
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/images/iconApp.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/iconApp.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.grocerylist.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/iconApp.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "028760af-1731-4743-92ac-4814c17e384d"
      }
    },
    "owner": "telmopersch"
  }
}
